<%- include('partials/header') %>
<main>
  <h1>SLGS Stats</h1>

  <h3>
    Lookup Drafter Profile (Just first name or first name last initial with no
    space in between)
  </h3>
  <form action="/search" method="GET">
    <input
      type="text"
      name="query"
      placeholder="Search for a drafter"
      required
    />
    <button type="submit">Search</button>
  </form>

  <div class="content">
    <h2>Season XV (3/26/26 - 6/26/26)</h2>
    <h3>31 Drafts in, last updated 4/11/26</h3>
  </div>
  <div class="data-table-container">
    <div class="data-table">
      <p>
        Weekday Drafts (Min 16 Drafts to Qualify)
        <!-- <br />

        Congrats to our Winrate Champion Luis and Most Wins Champion Clayton!!
        <br />
        Season XV will last from 3/26/26 to 6/26/26. Stats will be updated
        once there is enough data (probably after the Sat 4/11 drafts) -->
      </p>
      <table id="sortableTable">
        <thead>
          <tr>
            <% if(tableData.length > 0) { %> <%
            Object.keys(tableData[0]).forEach(function(key) { %>
            <th class="sortable" data-key="<%= key %>">
              <%= key %>
              <span class="sort-indicator"></span>
            </th>
            <% }); %> <% } %>
          </tr>
        </thead>
        <tbody>
          <% tableData.forEach(function(row) { %>
          <tr style="<%= row.total_drafts > 15 ? 'font-weight:bold;' : '' %>">
            <% Object.values(row).forEach(function(value) { %>
            <td><%= value %></td>
            <% }); %>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <p>
        Weekend Drafts (Min 8 Drafts to Qualify) 
      </p>
      <table id="sortableTable">
        <thead>
          <tr>
            <% if(weekendData.length > 0) { %> <%
            Object.keys(weekendData[0]).forEach(function(key) { %>
            <th class="sortable" data-key="<%= key %>">
              <%= key %>
              <span class="sort-indicator"></span>
            </th>
            <% }); %> <% } %>
          </tr>
        </thead>
        <tbody>
          <% weekendData.forEach(function(row) { %>
          <tr style="<%= row.total_drafts > 7 ? 'font-weight:bold;' : '' %>">
            <% Object.values(row).forEach(function(value) { %>
            <td><%= value %></td>
            <% }); %>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
